[profile.release]
opt-level = 3
lto = "fat"
codegen-units = 1
strip = "symbols"

[profile.bench]
opt-level = 3
lto = "fat"
codegen-units = 1

[profile.release-perf]
inherits = "release"
opt-level = 3
lto = "thin"
debug = "line-tables-only"
strip = false

[lints.rust]
# Default to deny for unsafe code - specific modules that require it can use #[allow(unsafe_code)]
# The epoll reactor requires unsafe for the polling crate's FFI operations
unexpected_cfgs = { level = "warn", check-cfg = ['cfg(loom)', 'cfg(fuzzing)', 'cfg(feature, values("quic", "http3", "wasm-browser-preview", "simd-intrinsics", "messaging-fabric", "obligation-cleanup-e2e"))'] }
unsafe_code = "deny"
# Public API documentation is tracked as release content, not as a compiler
# noise source during warning-clean release gates.
missing_docs = "allow"
unused = { level = "warn", priority = -1 }
# Proptest's prop_compose! expands doc comments on items the rust compiler can't
# attach docs to; downgrade so test suites using proptest compile under -D warnings.
unused_doc_comments = "allow"

[lints.clippy]
pedantic = { level = "warn", priority = -1 }
nursery = { level = "warn", priority = -1 }
module_name_repetitions = "allow"
must_use_candidate = "allow"
# Phase 0: Allow documentation and const lints for stubs
missing_panics_doc = "allow"
missing_errors_doc = "allow"
missing_const_for_fn = "allow"
# Phase 0: Allow module naming patterns
module_inception = "allow"
# Phase 0: Allow doc formatting patterns (math notation)
doc_markdown = "allow"
# Phase 0: Allow casts (arena is bounded at 2^32)
cast_possible_truncation = "allow"
# Many Duration::from_millis(1000) patterns are intentionally explicit about units
duration_suboptimal_units = "allow"
# Rust 2024 migration: postpone broad style-only rewrites from let-chain opportunities.
collapsible_if = "allow"
# WIP-module pedantic/nursery lints that are predominantly style issues in the
# epoch_gc, resource_monitor, cancellation_*, and channel verification harnesses.
# Not correctness concerns — just accumulated style debt during rapid design
# iteration. Downgraded to allow at the workspace level so `cargo clippy
# --all-targets -- -D warnings` passes while individual cleanup lands.
cast_precision_loss = "allow"
cast_sign_loss = "allow"
cast_lossless = "allow"
significant_drop_tightening = "allow"
significant_drop_in_scrutinee = "allow"
uninlined_format_args = "allow"
match_same_arms = "allow"
format_push_string = "allow"
float_cmp = "allow"
items_after_statements = "allow"
items_after_test_module = "allow"
needless_pass_by_value = "allow"
option_if_let_else = "allow"
unused_async = "allow"
unused_self = "allow"
redundant_clone = "allow"
redundant_closure_for_method_calls = "allow"
missing_fields_in_debug = "allow"
single_match = "allow"
single_match_else = "allow"
struct_excessive_bools = "allow"
default_trait_access = "allow"
unreadable_literal = "allow"
too_many_lines = "allow"
too_many_arguments = "allow"
type_complexity = "allow"
match_like_matches_macro = "allow"
unnecessary_wraps = "allow"
unnecessary_sort_by = "allow"
wrong_self_convention = "allow"
new_without_default = "allow"
should_implement_trait = "allow"
or_fun_call = "allow"
suboptimal_flops = "allow"
no_effect_underscore_binding = "allow"
used_underscore_binding = "allow"
similar_names = "allow"
result_large_err = "allow"
useless_vec = "allow"
format_collect = "allow"
unit_arg = "allow"
field_reassign_with_default = "allow"
assertions_on_constants = "allow"
manual_div_ceil = "allow"
manual_is_multiple_of = "allow"
len_zero = "allow"
large_enum_variant = "allow"
match_wild_err_arm = "allow"
branches_sharing_code = "allow"
read_zero_byte_vec = "allow"
unused_peekable = "allow"
collection_is_never_read = "allow"
manual_checked_ops = "allow"
arithmetic_side_effects = "allow"
must_use_unit = "allow"
needless_pass_by_ref_mut = "allow"
trivially_copy_pass_by_ref = "allow"
redundant_field_names = "allow"
bool_assert_comparison = "allow"
use_self = "allow"
redundant_else = "allow"
derive_partial_eq_without_eq = "allow"
return_self_not_must_use = "allow"
semicolon_if_nothing_returned = "allow"
if_not_else = "allow"
unnecessary_debug_formatting = "allow"
inefficient_to_string = "allow"
explicit_iter_loop = "allow"
explicit_into_iter_loop = "allow"
ptr_as_ptr = "allow"
borrow_as_ptr = "allow"
cognitive_complexity = "allow"
missing_inline_in_public_items = "allow"
option_option = "allow"
large_futures = "allow"
ignored_unit_patterns = "allow"
redundant_pattern_matching = "allow"
manual_let_else = "allow"
struct_field_names = "allow"
