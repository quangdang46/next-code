---
source: src/trace/distributed/vclock.rs
expression: "scrub_vclock_output(json!({\n    \"states\":\n    {\n        \"empty\":\n        {\n            \"display\": empty.to_string(), \"debug\": format!(\"{empty:?}\"),\n            \"node_count\": empty.node_count(), \"is_zero\": empty.is_zero()\n        }, \"single\":\n        {\n            \"display\": single.to_string(), \"debug\": format!(\"{single:?}\"),\n            \"node_count\": single.node_count(), \"is_zero\": single.is_zero()\n        }, \"merged\":\n        {\n            \"display\": merged.to_string(), \"debug\": format!(\"{merged:?}\"),\n            \"node_count\": merged.node_count(), \"is_zero\": merged.is_zero()\n        }, \"post_receive\":\n        {\n            \"display\": c.to_string(), \"debug\": format!(\"{c:?}\"), \"node_count\":\n            c.node_count(), \"is_zero\": c.is_zero()\n        }, \"set_zero_noop\":\n        {\n            \"display\": zero_set.to_string(), \"debug\": format!(\"{zero_set:?}\"),\n            \"is_zero\": zero_set.is_zero()\n        },\n    }, \"causal_orders\":\n    [{\n        \"case\": \"before\", \"lhs\": before_lhs.to_string(), \"rhs\":\n        before_rhs.to_string(), \"verdict\":\n        format!(\"{:?}\", before_lhs.causal_order(&before_rhs))\n    },\n    {\n        \"case\": \"after\", \"lhs\": before_rhs.to_string(), \"rhs\":\n        before_lhs.to_string(), \"verdict\":\n        format!(\"{:?}\", before_rhs.causal_order(&before_lhs))\n    },\n    {\n        \"case\": \"equal\", \"lhs\": equal_lhs.to_string(), \"rhs\":\n        equal_rhs.to_string(), \"verdict\":\n        format!(\"{:?}\", equal_lhs.causal_order(&equal_rhs))\n    },\n    {\n        \"case\": \"concurrent\", \"lhs\": concurrent_lhs.to_string(), \"rhs\":\n        concurrent_rhs.to_string(), \"verdict\":\n        format!(\"{:?}\", concurrent_lhs.causal_order(&concurrent_rhs))\n    },], \"iter_determinism\":\n    {\n        \"merged_keys_in_order\":\n        merged.iter().map(|(n, v)|\n        format!(\"{}={}\", n.as_str(), v)).collect::<Vec<_>>(),\n    }\n}))"
---
{
  "causal_orders": [
    {
      "case": "before",
      "lhs": "[[NODE_A]=1]",
      "rhs": "[[NODE_A]=2]",
      "verdict": "Before"
    },
    {
      "case": "after",
      "lhs": "[[NODE_A]=2]",
      "rhs": "[[NODE_A]=1]",
      "verdict": "After"
    },
    {
      "case": "equal",
      "lhs": "[[NODE_A]=1, [NODE_B]=1]",
      "rhs": "[[NODE_A]=1, [NODE_B]=1]",
      "verdict": "Equal"
    },
    {
      "case": "concurrent",
      "lhs": "[[NODE_A]=1]",
      "rhs": "[[NODE_B]=1]",
      "verdict": "Concurrent"
    }
  ],
  "iter_determinism": {
    "merged_keys_in_order": [
      "[NODE_A]=2",
      "[NODE_B]=1"
    ]
  },
  "states": {
    "empty": {
      "debug": "VC{}",
      "display": "[]",
      "is_zero": true,
      "node_count": 0
    },
    "merged": {
      "debug": "VC{[NODE_A]:2, [NODE_B]:1}",
      "display": "[[NODE_A]=2, [NODE_B]=1]",
      "is_zero": false,
      "node_count": 2
    },
    "post_receive": {
      "debug": "VC{[NODE_A]:2, [NODE_B]:2}",
      "display": "[[NODE_A]=2, [NODE_B]=2]",
      "is_zero": false,
      "node_count": 2
    },
    "set_zero_noop": {
      "debug": "VC{}",
      "display": "[]",
      "is_zero": true
    },
    "single": {
      "debug": "VC{[NODE_A]:1}",
      "display": "[[NODE_A]=1]",
      "is_zero": false,
      "node_count": 1
    }
  }
}
