  "event_kind": "obligation_abort",
  "kind": "lease",
  "obligation": "[obligation]",
  "region": "[region]",
  "schema_version": "browser-trace-schema-v1",
  "seq": "[seq]",
  "sequence_group": "[sequence_group]",
  "state": "aborted",
  "task": "[task]",
  "time_ns": "[time_ns]",
  "trace_id": "[trace_id]",
  "validation_failure_category": "none",
