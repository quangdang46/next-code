source: src/cli/completion.rs
expression: snapshot
---
{
  "bash": "# Bash completion for asupersync\n_asupersync_completions() {\n    local cur prev\n    cur=\"${COMP_WORDS[COMP_CWORD]}\"\n    prev=\"${COMP_WORDS[COMP_CWORD-1]}\"\n\n    local subcommands=\"serve trace doctor completion\"\n    local options=\"--config --profile --log-dir\"\n    local subcommand=\"\"\n    local subcommand_options=\"\"\n\n    local idx\n    for ((idx = 1; idx < COMP_CWORD; idx++)); do\n        case \"${COMP_WORDS[idx]}\" in\n            serve|trace|doctor|completion)\n                subcommand=\"${COMP_WORDS[idx]}\"\n                break\n                ;;\n        esac\n    done\n\n    case \"$subcommand\" in\n        serve) subcommand_options=\"--listen --tls-cert\" ;;\n        trace) subcommand_options=\"--input --format\" ;;\n        doctor) subcommand_options=\"--json --socket\" ;;\n        completion) subcommand_options=\"--shell --output\" ;;\n    esac\n\n    if [[ -z \"$subcommand\" ]]; then\n        COMPREPLY=( $(compgen -W \"$subcommands $options\" -- \"$cur\") )\n    else\n        COMPREPLY=( $(compgen -W \"$options $subcommand_options\" -- \"$cur\") )\n    fi\n}\n\ncomplete -F _asupersync_completions asupersync\n",
  "fish": "# Fish completion for asupersync\n\ncomplete -c asupersync -n '__fish_use_subcommand' -a 'serve' -d 'Run the network runtime'\ncomplete -c asupersync -n '__fish_use_subcommand' -a 'trace' -d 'Inspect traces in <ABS_TRACE_DIR>'\ncomplete -c asupersync -n '__fish_use_subcommand' -a 'doctor' -d 'Check runtime health'\ncomplete -c asupersync -n '__fish_use_subcommand' -a 'completion' -d 'Generate shell completions'\n\ncomplete -c asupersync -l 'config' -d 'Read <ABS_CONFIG_PATH>'\ncomplete -c asupersync -l 'profile' -d 'Select dev, staging, or prod'\ncomplete -c asupersync -l 'log-dir' -d 'Write logs under <ABS_LOG_DIR>'\n\ncomplete -c asupersync -n '__fish_seen_subcommand_from serve' -l 'listen' -d 'Bind 127.0.0.1:7447'\ncomplete -c asupersync -n '__fish_seen_subcommand_from serve' -l 'tls-cert' -d 'Use <ABS_TLS_CERT>'\ncomplete -c asupersync -n '__fish_seen_subcommand_from trace' -l 'input' -d 'Open <ABS_TRACE_FILE>'\ncomplete -c asupersync -n '__fish_seen_subcommand_from trace' -l 'format' -d 'Render json or markdown'\ncomplete -c asupersync -n '__fish_seen_subcommand_from doctor' -l 'json' -d 'Emit machine-readable output'\ncomplete -c asupersync -n '__fish_seen_subcommand_from doctor' -l 'socket' -d 'Probe <ABS_DOCTOR_SOCKET>'\ncomplete -c asupersync -n '__fish_seen_subcommand_from completion' -l 'shell' -d 'Target bash, zsh, or fish'\ncomplete -c asupersync -n '__fish_seen_subcommand_from completion' -l 'output' -d 'Write <ABS_OUTPUT_FILE>'\n",
  "zsh": "compdef _asupersync asupersync\n\n_asupersync() {\n    local context state line\n    local -a commands options subcommand_options current_items\n\n    commands=(\n        'serve:Run the network runtime'\n        'trace:Inspect traces in <ABS_TRACE_DIR>'\n        'doctor:Check runtime health'\n        'completion:Generate shell completions'\n    )\n\n    options=(\n        '--config[Read <ABS_CONFIG_PATH>]'\n        '--profile[Select dev, staging, or prod]'\n        '--log-dir[Write logs under <ABS_LOG_DIR>]'\n    )\n\n    _arguments -C -s \\\n        '1: :->command' \\\n        '*:: :->args'\n\n    case $state in\n        command)\n            _describe -t commands 'commands' commands\n            ;;\n        args)\n            local subcommand=''\n            subcommand_options=()\n            local idx\n            for (( idx = 2; idx < CURRENT; idx++ )); do\n                case $words[idx] in\n                    serve|trace|doctor|completion)\n                        subcommand=$words[idx]\n                        break\n                        ;;\n                esac\n            done\n            case $subcommand in\n                serve)\n                    subcommand_options=(\n                        '--listen[Bind 127.0.0.1:7447]'\n                        '--tls-cert[Use <ABS_TLS_CERT>]'\n                    )\n                    ;;\n                trace)\n                    subcommand_options=(\n                        '--input[Open <ABS_TRACE_FILE>]'\n                        '--format[Render json or markdown]'\n                    )\n                    ;;\n                doctor)\n                    subcommand_options=(\n                        '--json[Emit machine-readable output]'\n                        '--socket[Probe <ABS_DOCTOR_SOCKET>]'\n                    )\n                    ;;\n                completion)\n                    subcommand_options=(\n                        '--shell[Target bash, zsh, or fish]'\n                        '--output[Write <ABS_OUTPUT_FILE>]'\n                    )\n                    ;;\n            esac\n            if [[ -z $subcommand ]]; then\n                current_items=($commands $options)\n            else\n                current_items=($options $subcommand_options)\n            fi\n            _describe -t completions 'completions' current_items\n            ;;\n    esac\n}\n"
}
