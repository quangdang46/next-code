{"pid":[PID],"threshold":"trace","timestamp":"[TIMESTAMP]","level":"DEBUG","message":"debug-path"}
{"pid":[PID],"threshold":"trace","timestamp":"[TIMESTAMP]","level":"INFO","message":"info-path"}
{"pid":[PID],"threshold":"trace","timestamp":"[TIMESTAMP]","level":"WARN","message":"warn-path"}
{"pid":[PID],"threshold":"trace","timestamp":"[TIMESTAMP]","level":"ERROR","message":"error-path"}

[threshold=debug]
{"pid":[PID],"threshold":"debug","timestamp":"[TIMESTAMP]","level":"DEBUG","message":"debug-path"}
