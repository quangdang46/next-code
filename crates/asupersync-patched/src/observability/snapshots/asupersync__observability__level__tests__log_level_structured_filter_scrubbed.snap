{"pid":[PID],"threshold":"debug","timestamp":"[TIMESTAMP]","level":"WARN","message":"warn-path"}
{"pid":[PID],"threshold":"debug","timestamp":"[TIMESTAMP]","level":"ERROR","message":"error-path"}

[threshold=info]
{"pid":[PID],"threshold":"info","timestamp":"[TIMESTAMP]","level":"INFO","message":"info-path"}
{"pid":[PID],"threshold":"info","timestamp":"[TIMESTAMP]","level":"WARN","message":"warn-path"}
{"pid":[PID],"threshold":"info","timestamp":"[TIMESTAMP]","level":"ERROR","message":"error-path"}

[threshold=warn]
{"pid":[PID],"threshold":"warn","timestamp":"[TIMESTAMP]","level":"WARN","message":"warn-path"}
