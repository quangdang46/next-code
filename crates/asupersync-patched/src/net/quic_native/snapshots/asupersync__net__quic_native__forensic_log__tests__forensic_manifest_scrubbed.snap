    "by_category": {
      "quic_connection": 2,
      "test_harness": 1
    },
    "by_level": {
      "INFO": 3
    },
    "total_events": 3
  },
  "failure_class": "passed",
  "invariant_ids": [
    "inv.quic.handshake_completes"
  ],
  "invariant_verdicts": [
    {
      "details": "handshake finished in test harness",
      "invariant_id": "inv.quic.handshake_completes",
      "verdict": "pass"
    }
  ],
  "passed": true,
